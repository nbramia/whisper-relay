# Copy to .env and fill in your machine-specific values (never commit .env):
#   cp .env.example .env
#
# Required for running locally. DEPLOY_* and TAILNET_* are also read by
# scripts/install-autostart.sh when enabling headless boot.

VOICE_GATEWAY_HOST=127.0.0.1
VOICE_GATEWAY_PORT=8888
LIFEOS_BASE_URL=http://127.0.0.1:8000
TTS_BACKEND=kokoro
# See docs/adr/003-kokoro-tts-bm-george.md for Kokoro paths and voice settings

# Tailscale — optional reference URLs for your phone (see scripts/setup-tailscale.sh)
TAILNET_HTTPS_URL=https://your-machine.your-tailnet.ts.net
TAILNET_HTTP_PORT=8888

# systemd install (scripts/install-systemd-user.sh, scripts/install-systemd.sh)
DEPLOY_REPO_DIR=/path/to/whisper-relay
DEPLOY_ENV_FILE=/path/to/whisper-relay/.env
DEPLOY_UVICORN=uvicorn
DEPLOY_SYSTEMD_USER=your-linux-user
